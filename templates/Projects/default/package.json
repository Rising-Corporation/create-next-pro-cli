{
  "name": "my-next-pro",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.3.14"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "verify:rendering": "node --experimental-strip-types tests/rendering/verify-rendering.ts",
    "check": "prettier --check . && eslint . && tsc --noEmit && vitest run && next build && node --experimental-strip-types tests/rendering/verify-rendering.ts",
    "test:consumer": "node --experimental-strip-types tests/consumer/validate-template.ts",
    "audit": "node --experimental-strip-types scripts/audit.ts"
  },
  "dependencies": {
    "@radix-ui/react-slot": "1.3.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.31",
    "next-intl": "4.13.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "simple-icons": "16.26.0",
    "tailwind-merge": "3.6.0",
    "tailwindcss-animate": "1.0.7"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "prettier": "3.9.5",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "allowScripts": {
    "@parcel/watcher": true,
    "@swc/core": true,
    "sharp": true,
    "unrs-resolver": true
  }
}
