{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["bun", "node"],
    "verbatimModuleSyntax": true
  },
  "include": [
    "bin.bun.ts",
    "bin.node.ts",
    "scripts/**/*.ts",
    "src/**/*.ts",
    "tsup.config.ts"
  ],
  "exclude": ["dist", "my-next-app", "node_modules", "templates"]
}
